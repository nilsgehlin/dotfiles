#env variables
VIM="nvim"

export PATH=$DOTFILES/scripts:$PATH
# export PATH=$HOME/.dotnet/tools:$PATH

export DOTNET_ROOT=/usr/local/share/dotnet
export PATH=$DOTNET_ROOT:$PATH
# export PATH=$HOME/bin:$PATH

# wta: add a worktree for an existing or new branch, with branch name tab completion
wta() {
  if git show-ref --verify --quiet refs/heads/${1} || git show-ref --verify --quiet refs/remotes/origin/${1}; then
    git worktree add ~/projects/.worktree/${1} ${1}
  else
    git worktree add ~/projects/.worktree/${1} -b ${1}
  fi
}

#aliases
alias python=python3
alias vim=$VIM
alias c='cd $((fd --type d | fzf) || echo ".")'
alias oc='opencode attach http://127.0.0.1:51254/ --dir "$(git rev-parse --show-toplevel 2>/dev/null || pwd)"'

export EDITOR=$VIM

