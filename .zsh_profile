#env variables
VIM="nvim"

export PATH=$DOTFILES/scripts:$PATH
# export PATH=$HOME/.dotnet/tools:$PATH

export DOTNET_ROOT=/usr/local/share/dotnet
export PATH=$DOTNET_ROOT:$PATH
# export PATH=$HOME/bin:$PATH

#aliases
alias python=python3
alias vim=$VIM
alias c='cd $((fd --type d | fzf) || echo ".")'
alias oc='opencode attach http://127.0.0.1:51254/ --dir "$(git rev-parse --show-toplevel 2>/dev/null || pwd)"'

export EDITOR=$VIM

# alias curl=~/.local/bin/curlie
# alias ls=exa  
# alias gs=gitui
# eval $(thefuck --alias fk)
# alias journal='udisksctl mount -b /dev/sda && nvim /media/nige/nils-usb/journal/journal.md.cpt && udisksctl unmount -b /dev/sda'

bindkey -s ^f "tmux-sessionizer\n"


