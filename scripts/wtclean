#!/bin/bash

# wtclean - Remove git worktrees that have pushed all their changes to remote

# Color codes for output
RED='\033[0;31m'
GREEN='\033[0;32m'
YELLOW='\033[1;33m'
NC='\033[0m' # No Color

# Check if we're in a git repository
if ! git rev-parse --git-dir > /dev/null 2>&1; then
    echo -e "${RED}Error: Not a git repository${NC}"
    exit 1
fi

echo "Checking worktrees for branches that have been pushed to remote..."
echo ""

# Get list of worktrees, skipping the header and the main worktree
worktrees=$(git worktree list --porcelain)

removed_count=0
skipped_count=0
error_count=0

# Function to process a worktree entry
process_worktree() {
    local wt_path="$1"
    local wt_branch="$2"
    local wt_commit="$3"
    
    # Skip if no worktree path
    if [[ -z $wt_path ]]; then
        return
    fi
    
    # Skip the main worktree
    main_worktree=$(git rev-parse --show-toplevel)
    if [[ "$wt_path" == "$main_worktree" ]]; then
        return
    fi
    
    # Skip if no branch (detached HEAD)
    if [[ -z $wt_branch ]]; then
        echo -e "${YELLOW}Skipping${NC} $wt_path (detached HEAD)"
        ((skipped_count++))
        return
    fi
    
    # Check if branch has a remote tracking branch
    remote_branch=$(git config --get "branch.$wt_branch.merge" 2>/dev/null || echo "")
    remote_name=$(git config --get "branch.$wt_branch.remote" 2>/dev/null || echo "")
    
    if [[ -z $remote_branch ]] || [[ -z $remote_name ]]; then
        echo -e "${YELLOW}Skipping${NC} $wt_path [$wt_branch] (no remote tracking branch)"
        ((skipped_count++))
        return
    fi
    
    # Get the remote branch name
    remote_ref="${remote_branch#refs/heads/}"
    full_remote_ref="$remote_name/$remote_ref"
    
    # Check if remote branch exists
    if ! git rev-parse --verify "refs/remotes/$full_remote_ref" >/dev/null 2>&1; then
        echo -e "${YELLOW}Skipping${NC} $wt_path [$wt_branch] (remote branch $full_remote_ref not found)"
        ((skipped_count++))
        return
    fi
    
    # Get the commit hash of the remote branch
    remote_commit=$(git rev-parse "refs/remotes/$full_remote_ref")
    
    # Check if local and remote are in sync
    if [[ "$wt_commit" == "$remote_commit" ]]; then
        echo -e "${GREEN}Removing${NC} $wt_path [$wt_branch] (synced with $full_remote_ref)"
        
        # Remove the worktree
        if git worktree remove "$wt_path" 2>/dev/null; then
            ((removed_count++))
        elif git worktree remove "$wt_path" --force 2>/dev/null; then
            ((removed_count++))
        else
            echo -e "${RED}  Failed to remove worktree${NC}"
            ((error_count++))
        fi
    else
        # Check if local is ahead of remote
        ahead_count=$(git rev-list --count "refs/remotes/$full_remote_ref..$wt_commit" 2>/dev/null || echo "0")
        
        if [[ $ahead_count -gt 0 ]]; then
            echo -e "${YELLOW}Skipping${NC} $wt_path [$wt_branch] ($ahead_count commit(s) ahead of $full_remote_ref)"
        else
            echo -e "${YELLOW}Skipping${NC} $wt_path [$wt_branch] (not in sync with $full_remote_ref)"
        fi
        ((skipped_count++))
    fi
}

# Parse worktree list
current_worktree=""
current_branch=""
current_commit=""

while IFS= read -r line; do
    if [[ $line == worktree* ]]; then
        # Process previous worktree before starting new one
        if [[ -n $current_worktree ]]; then
            process_worktree "$current_worktree" "$current_branch" "$current_commit"
        fi
        
        # Start of a new worktree entry
        current_worktree="${line#worktree }"
        current_branch=""
        current_commit=""
    elif [[ $line == branch* ]]; then
        current_branch="${line#branch refs/heads/}"
    elif [[ $line == HEAD* ]]; then
        current_commit="${line#HEAD }"
    fi
done <<< "$worktrees"

# Process the last worktree
if [[ -n $current_worktree ]]; then
    process_worktree "$current_worktree" "$current_branch" "$current_commit"
fi

echo ""
echo "Summary:"
echo "  Removed: $removed_count"
echo "  Skipped: $skipped_count"
echo "  Errors: $error_count"
